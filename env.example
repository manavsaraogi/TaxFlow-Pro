# TaxFlow Pro — Environment Variables
# Copy this file to .env and fill in values before running the app.
# Never commit .env to version control.

# ─────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────

# SQLite database file path (relative to project root)
# Prisma uses this for all DB operations.
DATABASE_URL="file:./data/taxflow.db"

# ─────────────────────────────────────────
# VAULT / ENCRYPTION
# ─────────────────────────────────────────

# Salt used during vault key derivation (PBKDF2).
# Generate once with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# WARNING: Changing this after setup will make the vault unreadable.
VAULT_SALT=""

# Number of PBKDF2 iterations for master password key derivation.
# Minimum recommended: 310000 (NIST 2023). Default: 600000.
VAULT_KDF_ITERATIONS=600000

# ─────────────────────────────────────────
# ELECTRON / APP
# ─────────────────────────────────────────

# Set to "development" during dev, "production" for builds.
NODE_ENV=development

# Electron window dimensions (optional overrides)
# WINDOW_WIDTH=1280
# WINDOW_HEIGHT=800

# ─────────────────────────────────────────
# LOGGING
# ─────────────────────────────────────────

# Log level: error | warn | info | debug
LOG_LEVEL=info

# ─────────────────────────────────────────
# NEXT.JS RENDERER
# ─────────────────────────────────────────

# Internal port used by Next.js dev server (Electron loads from this)
RENDERER_PORT=3000

# ─────────────────────────────────────────
# DEV / SEED
# ─────────────────────────────────────────

# Set to "true" to run prisma/seed.ts automatically on first dev launch
AUTO_SEED=false

# Master password used by seed script ONLY — never use in production
SEED_MASTER_PASSWORD=DevPassword@123
